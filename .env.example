APP_ENV=local
APP_DEBUG=true
APP_KEY=

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=launchpilot
DB_USERNAME=launchpilot
DB_PASSWORD=launchpilot

VITE_DEV_SERVER_URL=http://localhost:5173
VITE_USE_DEV_SERVER=true

INERTIA_SSR_ENABLED=false
INERTIA_SSR_URL=http://localhost:13714

SESSION_DRIVER=file
ENCRYPTION_KEY=

# Logging
LOG_DRIVER=file
LOG_PATH=storage/logs
LOG_LEVEL=debug
LOG_CHANNEL=launchpilot

# Cache (Redis is the default in Docker)
CACHE_DRIVER=redis
CACHE_REDIS_HOST=127.0.0.1
CACHE_REDIS_PORT=6379
CACHE_REDIS_DB=0
CACHE_REDIS_PREFIX="launchpilot:cache:"
CACHE_TTL=3600

# Queue
QUEUE_DRIVER=database
