<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{$title ?? 'LaunchPilot AI'}</title>
    <meta name="description" content="AI-driven marketing campaign planning for small businesses and entrepreneurs.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', '-apple-system', 'BlinkMacSystemFont', 'Segoe UI', 'Roboto', 'sans-serif'],
                    },
                    colors: {
                        ink: '#0f172a',
                        muted: '#64748b',
                        line: '#e2e8f0',
                        paper: '#f8fafc',
                        surface: '#ffffff',
                        accent: '#3b82f6',
                        green: '#22c55e',
                        amber: '#f59e0b',
                        red: '#ef4444',
                    },
                    boxShadow: {
                        'elevation-1': '0 1px 3px rgba(0,0,0,0.06)',
                        'elevation-2': '0 4px 12px rgba(0,0,0,0.08)',
                        'elevation-3': '0 8px 24px rgba(0,0,0,0.10)',
                        'elevation-4': '0 12px 32px rgba(0,0,0,0.12)',
                        'elevation-hover': '0 6px 16px rgba(0,0,0,0.09)',
                    },
                    borderRadius: {
                        'card': '12px',
                        'button': '8px',
                        'modal': '16px',
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
        .animate-fade-in { animation: fadeIn 200ms ease-out; }
        .animate-slide-up { animation: slideUp 200ms ease-out; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes slideUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body class="bg-paper text-ink antialiased">
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-line">
        <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4" aria-label="Primary">
            <a href="/" class="text-lg font-bold tracking-tight flex items-center gap-2">
                <span class="inline-flex h-8 w-8 items-center justify-center rounded-button bg-ink text-white text-sm font-bold">LP</span>
                LaunchPilot
            </a>
            <div class="flex items-center gap-6">
                <a href="/login" class="text-sm font-semibold text-muted hover:text-ink transition-colors">Log in</a>
                <a href="/register" class="rounded-button bg-ink px-4 py-2 text-sm font-semibold text-white hover:bg-ink/90 shadow-elevation-1 hover:shadow-elevation-2 transition-all hover:-translate-y-0.5">Get started</a>
            </div>
        </nav>
    </header>

    <main>
        {block content}{/block}
    </main>

    <footer class="border-t border-line mt-20 bg-white">
        <div class="mx-auto max-w-6xl px-6 py-10">
            <div class="flex flex-col md:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-2">
                    <span class="inline-flex h-7 w-7 items-center justify-center rounded-button bg-ink text-white text-xs font-bold">LP</span>
                    <span class="text-sm font-semibold">LaunchPilot AI</span>
                </div>
                <p class="text-sm text-muted">Built for owner-led businesses.</p>
                <p class="text-sm text-muted">&copy; {=date('Y')} LaunchPilot AI</p>
            </div>
        </div>
    </footer>
</body>
</html>
