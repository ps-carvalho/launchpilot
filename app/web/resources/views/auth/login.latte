{layout 'web::layouts/main'}

{block content}
<section class="mx-auto max-w-md px-6 py-16 md:py-24">
    <div class="rounded-card bg-surface p-8 border border-line/60 shadow-elevation-2 animate-slide-up">
        <div class="text-center mb-6">
            <div class="inline-flex h-10 w-10 items-center justify-center rounded-button bg-ink text-white text-sm font-bold mb-4">LP</div>
            <h1 class="text-2xl font-bold">Welcome back</h1>
            <p class="mt-1 text-sm text-muted">Enter your details to continue.</p>
        </div>

        {if isset($flash) && count($flash) > 0}
            {foreach $flash as $message}
                <div class="mb-4 rounded-button bg-red-50 px-4 py-3 text-sm font-semibold text-red-600 border border-red-100">
                    {$message}
                </div>
            {/foreach}
        {/if}

        <form action="/login" method="post" class="space-y-4">
            <input type="hidden" name="_token" value="{$csrf_token}">
            <div>
                <label for="email" class="block text-sm font-medium text-ink mb-1.5">Email</label>
                <input id="email" name="email" type="email" required placeholder="you@company.com" class="w-full rounded-button border border-line bg-paper px-4 py-2.5 text-sm text-ink placeholder:text-muted/60 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition-all">
            </div>
            <div>
                <label for="password" class="block text-sm font-medium text-ink mb-1.5">Password</label>
                <input id="password" name="password" type="password" required placeholder="••••••••" class="w-full rounded-button border border-line bg-paper px-4 py-2.5 text-sm text-ink placeholder:text-muted/60 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition-all">
            </div>
            <button type="submit" class="w-full rounded-button bg-ink px-4 py-2.5 text-sm font-bold text-white hover:bg-ink/90 shadow-elevation-1 hover:shadow-elevation-2 transition-all hover:-translate-y-0.5">Log in</button>
        </form>

        <p class="mt-6 text-center text-sm text-muted">
            Don't have an account? <a href="/register" class="font-semibold text-ink hover:text-accent transition-colors">Get started</a>
        </p>
    </div>
</section>
{/block}
