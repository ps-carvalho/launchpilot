#!/usr/bin/env bash
set -euo pipefail

PHP_PID=""
VITE_PID=""

cleanup() {
    echo ""
    echo "Shutting down dev servers..."
    if [ -n "$PHP_PID" ]; then
        kill "$PHP_PID" 2>/dev/null || true
        wait "$PHP_PID" 2>/dev/null || true
    fi
    if [ -n "$VITE_PID" ]; then
        kill "$VITE_PID" 2>/dev/null || true
        wait "$VITE_PID" 2>/dev/null || true
    fi
    exit 0
}

trap cleanup INT TERM EXIT

echo "Starting PHP dev server (http://localhost:8000)..."
php -S localhost:8000 -t public/ > /tmp/php-server.log 2>&1 &
PHP_PID=$!

sleep 1

if ! kill -0 "$PHP_PID" 2>/dev/null; then
    echo "PHP server failed to start. Check /tmp/php-server.log"
    cat /tmp/php-server.log
    exit 1
fi

echo "Starting Vite dev server (http://localhost:5173)..."
npx vite &
VITE_PID=$!

wait "$VITE_PID"
